---
import Base from '../../layouts/Base.astro';
import { galaceanDemos, galaceanRepoUrl } from '../../labs/galacean-1-1/demoCatalog';
---

<Base title="Galacean 1.1 Beta Tests | sylvanyu.io" description="Archived Galacean 1.1 beta shader and material tests from 2023-2024.">
  <main class="page">
    <header class="topbar">
      <a class="brand" href="/">sylvanyu.io</a>
      <nav>
        <a href="/labs/">Labs</a>
        <a href={galaceanRepoUrl} rel="noreferrer">Repo</a>
      </nav>
    </header>

    <section class="hero">
      <div class="copy">
        <p class="kicker">Archive / 2023-2024</p>
        <h1>Galacean 1.1 beta tests.</h1>
        <p>
          Old Galacean Engine tests around water, gem/ice, skin, and post-processing. They are
          kept close to the original repo instead of being rebuilt as polished portfolio work.
        </p>
      </div>
      <div class="visual" aria-hidden="true">
        <div class="tile water">
          <span>water</span>
        </div>
        <div class="tile gem">
          <span>gem</span>
        </div>
        <div class="tile skin">
          <span>skin</span>
        </div>
        <div class="tile post">
          <span>post</span>
        </div>
      </div>
    </section>

    <section class="demos" aria-label="Galacean demos">
      {galaceanDemos.map((demo) => (
        <a class="demo-card" href={demo.href}>
          <div class="route">{demo.category}</div>
          <div>
            <h2>{demo.title}</h2>
            <p>{demo.summary}</p>
            <span>Open test</span>
          </div>
        </a>
      ))}
    </section>

    <section class="notes">
      <h2>Notes</h2>
      <ul>
        <li>These are old exploration demos, not finished project pages.</li>
        <li>Each test is mounted as a separate Astro island page.</li>
        <li>Most assets still load from CDN URLs used at the time.</li>
        <li>Dependencies are pinned to old Galacean beta packages.</li>
        <li>Source repo: <a href={galaceanRepoUrl} rel="noreferrer">Galacean-1.1-Demo</a>.</li>
      </ul>
    </section>
  </main>
</Base>

<style>
  .page {
    min-height: 100svh;
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 24px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 8px 0 56px;
  }

  .brand,
  nav a {
    text-decoration: none;
  }

  .brand {
    font-weight: 650;
  }

  nav {
    display: flex;
    gap: 18px;
    color: var(--muted);
    font-size: 14px;
  }

  nav a:hover {
    color: var(--text);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 28px;
    align-items: stretch;
    min-width: 0;
  }

  .copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 430px;
    min-width: 0;
  }

  .kicker {
    margin: 0 0 12px;
    color: var(--blue);
    font-size: 13px;
    font-weight: 650;
  }

  h1 {
    margin: 0;
    max-width: 720px;
    font-size: clamp(36px, 6.5vw, 70px);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .copy > p:not(.kicker) {
    max-width: 620px;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: 17px;
  }

  .visual {
    width: 100%;
    min-width: 0;
    min-height: 430px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1.15fr 0.85fr;
    gap: 1px;
    overflow: hidden;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .tile {
    position: relative;
    min-height: 0;
    min-width: 0;
  }

  .tile span {
    position: absolute;
    left: 14px;
    bottom: 12px;
    color: rgba(255,255,255,.78);
    font-size: 12px;
    font-weight: 650;
  }

  .water { background: #2c7f8f; }
  .gem { background: #6f5cd1; }
  .skin { background: #c9836b; }
  .post { background: #171a22; }

  .demos {
    display: grid;
    gap: 12px;
    margin-top: 36px;
  }

  .demo-card,
  .notes {
    min-width: 0;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .demo-card {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    gap: 18px;
    padding: 18px;
    color: inherit;
    text-decoration: none;
  }

  .demo-card:hover {
    border-color: #3b4256;
    background: var(--surface-2);
  }

  .route {
    color: var(--green);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
  }

  h2 {
    margin: 0 0 6px;
    font-size: 19px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .demo-card p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
  }

  .demo-card span {
    display: inline-block;
    margin-top: 10px;
    color: var(--green);
    font-size: 13px;
    font-weight: 650;
  }

  .notes {
    margin-top: 12px;
    padding: 18px;
  }

  .notes ul {
    margin: 10px 0 0;
    padding-left: 20px;
    color: var(--muted);
  }

  .notes li + li {
    margin-top: 4px;
  }

  @media (max-width: 820px) {
    .page {
      max-width: 100%;
      padding: 18px;
    }
    .topbar { padding-bottom: 38px; }
    .hero {
      width: 100%;
      grid-template-columns: minmax(0, 1fr);
    }
    .copy {
      max-width: calc(100vw - 36px);
      min-height: auto;
    }
    .visual,
    .demos,
    .demo-card,
    .notes {
      width: calc(100vw - 36px);
      max-width: calc(100vw - 36px);
    }
    .visual { min-height: 260px; }
  }

  @media (max-width: 560px) {
    .topbar {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
      padding-bottom: 36px;
    }

    nav {
      gap: 14px;
    }

    .copy,
    .visual,
    .demos,
    .demo-card,
    .notes {
      width: 100%;
      max-width: 340px;
    }

    .demo-card {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
