---
import Base from '../../../layouts/Base.astro';
import { liquidGlassDemos } from '../../../labs/liquid-glass/demoCatalog';
---

<Base
  title="Liquid Glass | sylvanyu.io"
  description="Liquid Glass demos for SVG displacement filters and a Three.js canvas shader pass."
>
  <main class="page">
    <header class="topbar">
      <a class="brand" href="/">sylvanyu.io</a>
      <nav>
        <a href="/labs/">Labs</a>
        <a href="https://github.com/sylvanyu-io" rel="noreferrer">GitHub</a>
      </nav>
    </header>

    <section class="hero">
      <div class="copy">
        <p class="kicker">Liquid Glass</p>
        <h1>Liquid glass experiments.</h1>
        <p>
          Two focused versions of the same material idea: one keeps the original SVG
          displacement-map pipeline visible, the other ports the lens into a Three.js
          fragment shader for canvas/WebGL surfaces.
        </p>
      </div>
      <div class="visual" aria-hidden="true">
        <div class="scene">
          <span class="flower one"></span>
          <span class="flower two"></span>
          <span class="flower three"></span>
          <span class="stem one"></span>
          <span class="stem two"></span>
          <span class="lens"></span>
        </div>
      </div>
    </section>

    <section class="demos" aria-label="Liquid Glass demos">
      {liquidGlassDemos.map((demo) => (
        <a class="demo-card" href={demo.href}>
          <div class="route">{demo.category}</div>
          <div>
            <h2>{demo.title}</h2>
            <p>{demo.summary}</p>
            <span>Open demo</span>
          </div>
        </a>
      ))}
    </section>

    <section class="notes">
      <h2>Notes</h2>
      <ul>
        <li>SVG and Canvas are separated so each runtime can be inspected without the other demo competing for scroll space.</li>
        <li>The Canvas version uses Three.js only for the renderer and fullscreen pass; the liquid lens is custom GLSL.</li>
        <li>The Canvas radius is computed in pixel space so non-square lenses keep a correct rounded-rectangle shape.</li>
      </ul>
    </section>
  </main>
</Base>

<style>
  .page {
    min-height: 100svh;
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 24px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 8px 0 56px;
  }

  .brand,
  nav a {
    text-decoration: none;
  }

  .brand {
    font-weight: 650;
  }

  nav {
    display: flex;
    gap: 18px;
    color: var(--muted);
    font-size: 14px;
  }

  nav a:hover {
    color: var(--text);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, .9fr);
    gap: 28px;
    align-items: stretch;
    min-width: 0;
  }

  .copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 430px;
    min-width: 0;
  }

  .kicker {
    margin: 0 0 12px;
    color: var(--green);
    font-size: 13px;
    font-weight: 650;
  }

  h1 {
    margin: 0;
    max-width: 720px;
    font-size: clamp(36px, 6.5vw, 70px);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .copy > p:not(.kicker) {
    max-width: 640px;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: 17px;
  }

  .visual {
    width: 100%;
    min-width: 0;
    min-height: 430px;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .scene {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 430px;
    overflow: hidden;
    background:
      radial-gradient(circle at 30% 72%, rgba(250, 124, 36, .95) 0 4%, transparent 4.6%),
      radial-gradient(circle at 72% 38%, rgba(250, 124, 36, .92) 0 3.6%, transparent 4.2%),
      radial-gradient(circle at 58% 70%, rgba(245, 166, 54, .9) 0 5.8%, transparent 6.4%),
      linear-gradient(145deg, #0d6f96 0%, #0a263f 56%, #10151c 100%);
  }

  .scene::before {
    position: absolute;
    inset: 0;
    content: "";
    background-image:
      linear-gradient(68deg, transparent 0 46%, rgba(126, 224, 138, .18) 47% 48%, transparent 49% 100%),
      linear-gradient(102deg, transparent 0 54%, rgba(126, 224, 138, .13) 55% 56%, transparent 57% 100%);
    background-size: 92px 100%, 74px 100%;
    opacity: .75;
  }

  .flower,
  .stem,
  .lens {
    position: absolute;
    display: block;
  }

  .flower {
    width: 74px;
    height: 96px;
    background: linear-gradient(165deg, #ffbc47 0 16%, #ff6b21 46%, #b72d14 100%);
    border-radius: 68% 32% 58% 42% / 74% 42% 58% 26%;
    box-shadow: 0 18px 42px rgba(0, 0, 0, .24);
  }

  .flower.one {
    left: 18%;
    bottom: 12%;
    transform: rotate(-18deg);
  }

  .flower.two {
    right: 16%;
    top: 18%;
    transform: rotate(22deg) scale(.86);
  }

  .flower.three {
    right: 30%;
    bottom: 18%;
    transform: rotate(8deg) scale(1.1);
  }

  .stem {
    bottom: -18%;
    width: 4px;
    height: 56%;
    background: linear-gradient(#86c862, #19321f);
    border-radius: 999px;
    transform-origin: bottom center;
  }

  .stem.one {
    left: 30%;
    transform: rotate(17deg);
  }

  .stem.two {
    right: 36%;
    transform: rotate(-12deg);
  }

  .lens {
    left: 50%;
    top: 31%;
    width: min(62%, 310px);
    aspect-ratio: 3.2 / 1;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, .36), transparent 42%),
      rgba(200, 254, 244, .17);
    border: 1px solid rgba(255, 255, 255, .32);
    border-radius: 999px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .58),
      inset 0 -14px 28px rgba(255, 255, 255, .08),
      0 18px 46px rgba(0, 0, 0, .26);
    transform: translateX(-50%);
    backdrop-filter: blur(10px) saturate(150%);
    -webkit-backdrop-filter: blur(10px) saturate(150%);
  }

  .demos {
    display: grid;
    gap: 12px;
    margin-top: 36px;
  }

  .demo-card,
  .notes {
    min-width: 0;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .demo-card {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: 18px;
    padding: 18px;
    color: inherit;
    text-decoration: none;
  }

  .demo-card:hover {
    border-color: #3b4256;
    background: var(--surface-2);
  }

  .route {
    color: var(--green);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
  }

  h2 {
    margin: 0 0 6px;
    font-size: 19px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .demo-card p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
  }

  .demo-card span {
    display: inline-block;
    margin-top: 10px;
    color: var(--green);
    font-size: 13px;
    font-weight: 650;
  }

  .notes {
    margin-top: 12px;
    padding: 18px;
  }

  .notes ul {
    margin: 10px 0 0;
    padding-left: 20px;
    color: var(--muted);
  }

  .notes li + li {
    margin-top: 4px;
  }

  @media (max-width: 820px) {
    .page {
      max-width: 100%;
      padding: 18px;
    }

    .topbar {
      padding-bottom: 38px;
    }

    .hero {
      width: 100%;
      grid-template-columns: minmax(0, 1fr);
    }

    .copy {
      max-width: calc(100vw - 36px);
      min-height: auto;
    }

    .visual,
    .scene {
      min-height: 320px;
    }

    .demo-card {
      grid-template-columns: 1fr;
      gap: 10px;
    }
  }

  @media (max-width: 560px) {
    .topbar {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    nav {
      flex-wrap: wrap;
      gap: 14px;
    }
  }
</style>
