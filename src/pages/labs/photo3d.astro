---
import Photo3DIsland from '../../components/labs/Photo3DIsland.astro';
import Base from '../../layouts/Base.astro';
---

<Base title="Photo3D | sylvanyu.io" description="A small WebGL parallax demo using layered disparity sprites.">
  <main class="page">
    <header class="topbar">
      <a class="brand" href="/">sylvanyu.io</a>
      <nav>
        <a href="/labs/">Labs</a>
        <a href="https://github.com/sylvanyu-io" rel="noreferrer">GitHub</a>
      </nav>
    </header>

    <section class="intro">
      <p class="kicker">WebGL / LDI</p>
      <h1>Photo3D.</h1>
      <p>
        A small WebGL parallax demo using a layered disparity sprite. It keeps the original shader
        test as an interactive lab page.
      </p>
    </section>

    <Photo3DIsland />

    <section class="details" aria-label="Photo3D details">
      <div>
        <span>Default image</span>
        <strong>src/labs/photo3d/textures/sprite1.png</strong>
      </div>
      <div>
        <span>Shader</span>
        <strong>src/labs/photo3d/photo3d.fs</strong>
      </div>
    </section>
  </main>
</Base>

<style>
  .page {
    width: 100%;
    min-width: 0;
    min-height: 100svh;
    max-width: 1180px;
    margin: 0 auto;
    padding: 24px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 8px 0 54px;
  }

  .brand,
  nav a {
    text-decoration: none;
  }

  .brand {
    font-weight: 650;
  }

  nav {
    display: flex;
    gap: 18px;
    color: var(--muted);
    font-size: 14px;
  }

  nav a:hover {
    color: var(--text);
  }

  .intro {
    width: 100%;
    min-width: 0;
    max-width: 760px;
    margin-bottom: 24px;
  }

  .kicker {
    margin: 0 0 10px;
    color: var(--green);
    font-size: 13px;
    font-weight: 650;
  }

  h1 {
    margin: 0;
    font-size: clamp(34px, 6vw, 66px);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .intro > p:not(.kicker) {
    max-width: 680px;
    margin: 16px 0 0;
    color: var(--muted);
    font-size: 16px;
  }

  .details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 12px;
  }

  .details div {
    min-width: 0;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .details span {
    display: block;
    color: var(--muted);
    font-size: 12px;
  }

  .details strong {
    display: block;
    margin-top: 6px;
    overflow-wrap: anywhere;
    font-size: 15px;
    font-weight: 650;
  }

  @media (max-width: 760px) {
    .page {
      padding: 18px;
    }

    .topbar {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
      padding-bottom: 38px;
    }

    nav {
      flex-wrap: wrap;
      gap: 14px;
    }

    .intro > p:not(.kicker) {
      max-width: 34ch;
    }

    .details {
      grid-template-columns: 1fr;
    }
  }
</style>
