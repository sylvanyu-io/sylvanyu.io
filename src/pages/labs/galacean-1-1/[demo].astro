---
import Base from '../../../layouts/Base.astro';
import GalaceanCanvasIsland from '../../../components/labs/GalaceanCanvasIsland.astro';
import { galaceanDemos, galaceanRepoUrl, type GalaceanDemo } from '../../../labs/galacean-1-1/demoCatalog';

export function getStaticPaths() {
  return galaceanDemos.map((demo) => ({
    params: { demo: demo.slug },
    props: { demo },
  }));
}

const { demo } = Astro.props as { demo: GalaceanDemo };
---

<Base title={`${demo.title} | sylvanyu.io`} description={demo.summary}>
  <main class="page">
    <header class="topbar">
      <a class="brand" href="/">SYLVAN YU — 俞宇锋</a>
      <nav>
        <a href="/labs/">Labs</a>
        <a href="/labs/galacean-1-1/">Galacean</a>
        <a href={galaceanRepoUrl} rel="noreferrer">Repo</a>
      </nav>
    </header>

    <section class="intro">
      <p class="kicker">{demo.category}</p>
      <h1>{demo.title}</h1>
      <p>{demo.summary}</p>
    </section>

    <GalaceanCanvasIsland family="galacean-1-1" scene={demo.slug} title={demo.title} category={demo.category} />

    <section class="details" aria-label="Demo details">
      <div>
        <span>Old repo route</span>
        <strong>{demo.sourceRoute}</strong>
      </div>
      <div>
        <span>Source</span>
        <a href={galaceanRepoUrl} rel="noreferrer">GitHub repository</a>
      </div>
    </section>
  </main>
</Base>

<style>
  .page {
    min-height: 100svh;
    max-width: 1180px;
    margin: 0 auto;
    padding: 24px clamp(20px, 5vw, 64px) 72px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 0 0 54px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .brand,
  nav a {
    text-decoration: none;
  }

  .brand {
    color: var(--text);
    font-weight: 500;
  }

  nav {
    display: flex;
    gap: 18px;
  }

  nav a:hover {
    color: var(--text);
  }

  .intro {
    max-width: 760px;
    margin-bottom: 24px;
    padding-top: 58px;
    border-top: 1px solid var(--line);
  }

  .kicker {
    margin: 0 0 10px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(34px, 6vw, 66px);
    line-height: 1.04;
    letter-spacing: -0.025em;
  }

  .intro > p:not(.kicker) {
    max-width: 680px;
    margin: 16px 0 0;
    color: var(--muted);
    font-size: 16px;
  }

  .details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 12px;
  }

  .details div {
    min-width: 0;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 6px;
  }

  .details span {
    display: block;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .details strong,
  .details a {
    display: block;
    margin-top: 6px;
    font-size: 15px;
    font-weight: 600;
  }

  .details a {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 760px) {
    .page {
      padding: 18px;
    }

    .topbar {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
      padding-bottom: 38px;
    }

    nav {
      flex-wrap: wrap;
      gap: 14px;
    }

    .details {
      grid-template-columns: 1fr;
    }
  }
</style>
