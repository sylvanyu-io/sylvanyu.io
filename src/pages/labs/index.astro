---
import Base from '../../layouts/Base.astro';
import { labEntries } from '../../labs/catalog';

const labCoverMap = {
  'liquid-glass': '/lab-covers/liquid-svg.jpg',
  photo3d: '/lab-covers/photo3d.jpg',
  'galacean-1-1': '/lab-covers/galacean-water.jpg',
  'galacean-0-9': '/lab-covers/galacean09-planar-reflection.jpg',
} as const;

const labCards = labEntries.map((lab, index) => ({
  ...lab,
  cover: labCoverMap[lab.slug as keyof typeof labCoverMap],
  no: String(index + 1).padStart(2, '0'),
}));
---

<Base title="Labs | sylvanyu.io" description="Small demos, notes, and archive experiments by Sylvan Yu.">
  <main class="page">
    <header class="topbar">
      <a class="brand" href="/">SYLVAN YU — 俞宇锋</a>
      <nav>
        <a href="/labs/">Labs</a>
        <a href="https://github.com/sylvanyu-io" rel="noreferrer">GitHub</a>
      </nav>
    </header>

    <section class="intro">
      <p class="kicker">Labs</p>
      <h1>Demos that run in your browser.</h1>
      <p>
        Interactive experiments and archived render-pipeline work — shaders, water, glass, and
        parallax photos. Everything here runs live; the older pieces are kept close to their
        original state as a record of how they were built.
      </p>
    </section>

    <section class="grid" aria-label="Lab entries">
      {labCards.map((lab) => (
        <article class="lab-card">
          <a class="main-link" href={lab.href}>
            <div class="media" aria-hidden="true">
              <img src={lab.cover} alt="" loading="lazy" decoding="async" />
            </div>
            <div class="body">
              <div class="meta-row">
                <span>{lab.no}</span>
                <span>{lab.meta}</span>
              </div>
              <h2>{lab.title}</h2>
              <p>{lab.description}</p>
            </div>
          </a>
          <div class="source-row" aria-label={`${lab.title} source links`}>
            {lab.sourceLinks.length ? (
              lab.sourceLinks.map((source) => (
                <a href={source.href} rel="noreferrer">{source.label}</a>
              ))
            ) : (
              <span>No public source link</span>
            )}
          </div>
        </article>
      ))}
    </section>
  </main>
</Base>

<style>
  .page {
    min-height: 100svh;
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px clamp(20px, 5vw, 64px) 72px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 0 0 64px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .brand,
  nav a {
    text-decoration: none;
  }

  .brand {
    color: var(--text);
    font-weight: 500;
  }

  nav {
    display: flex;
    gap: 18px;
  }

  nav a:hover {
    color: var(--text);
  }

  .intro {
    max-width: 720px;
    margin-bottom: 44px;
    padding-top: 58px;
    border-top: 1px solid var(--line);
  }

  .kicker {
    margin: 0 0 10px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
  }

  h1 {
    margin: 0;
    max-width: 780px;
    font-size: clamp(36px, 7vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.025em;
  }

  .intro > p:not(.kicker) {
    max-width: 620px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 17px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .lab-card {
    overflow: hidden;
    color: inherit;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 6px;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .lab-card:hover {
    border-color: rgba(242, 241, 237, 0.24);
    background: var(--surface-2);
    transform: translateY(-2px);
  }

  .main-link {
    display: grid;
    grid-template-rows: 220px 1fr;
    color: inherit;
    text-decoration: none;
  }

  .media {
    position: relative;
    min-height: 0;
    background: #050609;
    border-bottom: 1px solid var(--line);
  }

  .media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.98) contrast(0.98);
  }

  .body {
    padding: 18px;
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  h2 {
    margin: 14px 0 8px;
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .body p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
  }

  .source-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    padding: 0 18px 16px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .source-row a {
    color: var(--accent);
    text-decoration: none;
  }

  .source-row a:hover {
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .page { padding: 18px; }
    .topbar { padding-bottom: 44px; }
    .grid { grid-template-columns: 1fr; }
    .main-link { grid-template-rows: 190px 1fr; }
  }

  @media (max-width: 560px) {
    .topbar {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
      padding-bottom: 36px;
    }

    nav {
      gap: 14px;
    }
  }
</style>
