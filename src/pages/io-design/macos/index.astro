---
import Base from '../../../layouts/Base.astro';
import '../../../styles/io/macos.css';
---

<Base title="IO Design B · Sylvan OS" description="macOS-inspired personal site page rendered in one Three.js canvas.">
  <Fragment slot="head">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="mac-page" data-mac-single-canvas-root>
    <canvas
      class="mac-single-canvas"
      data-mac-single-canvas
      aria-label="Sylvan OS desktop rendered with Photo3D and liquid glass in one Three.js canvas"
    ></canvas>
    <noscript>
      <p class="mac-noscript">This page needs JavaScript to render the canvas desktop.</p>
    </noscript>
  </div>

  <script>
    import { mountMacSingleCanvases } from '../../../io/runtime/macSingleCanvas';

    mountMacSingleCanvases();
  </script>
</Base>
