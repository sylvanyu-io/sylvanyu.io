---
import demoBackgroundUrl from '../../labs/liquid-glass/textures/demo-background.jpg?url';

type CanvasControl = {
  name: string;
  label: string;
  min: number;
  max: number;
  step: number;
  value: number;
  decimals: number;
};

const canvasControls: CanvasControl[] = [
  { name: 'width', label: 'Width', min: 0.18, max: 0.56, step: 0.001, value: 0.34, decimals: 3 },
  { name: 'height', label: 'Height', min: 0.12, max: 0.44, step: 0.001, value: 0.26, decimals: 3 },
  { name: 'radius', label: 'Radius', min: 0, max: 0.5, step: 0.01, value: 0.5, decimals: 2 },
  { name: 'strength', label: 'Strength', min: 0, max: 0.2, step: 0.001, value: 0.11, decimals: 3 },
  { name: 'chroma', label: 'Chroma', min: 0, max: 0.8, step: 0.001, value: 0.34, decimals: 3 },
  { name: 'frost', label: 'Frost', min: 0, max: 1, step: 0.001, value: 0.18, decimals: 3 },
  { name: 'tint', label: 'Tint', min: 0, max: 1, step: 0.001, value: 0.36, decimals: 3 },
];

function rangePercent(control: CanvasControl) {
  const pct = ((control.value - control.min) / (control.max - control.min)) * 100;
  return Math.min(100, Math.max(0, Number(pct.toFixed(3))));
}
---

<section class="liquid-canvas" data-liquid-canvas-root data-liquid-canvas-texture={demoBackgroundUrl}>
  <div class="stage-meta">
    <span>Three.js / fragment shader</span>
    <strong>Canvas Liquid Glass</strong>
  </div>

  <div class="canvas-stage" data-liquid-canvas-stage aria-label="Canvas liquid glass shader demo">
    <canvas data-liquid-canvas></canvas>
    <div class="shader-badge">
      <span>WebGL pass</span>
      <strong data-liquid-canvas-status>Loading texture...</strong>
    </div>
  </div>

  <div class="controls" aria-label="Canvas liquid glass controls">
    {canvasControls.map((control) => (
      <label class="control">
        <span>{control.label}</span>
        <input
          data-liquid-canvas-control={control.name}
          type="range"
          min={control.min}
          max={control.max}
          step={control.step}
          value={control.value}
          style={`--range-percent: ${rangePercent(control)}%;`}
        />
        <output data-liquid-canvas-output={control.name}>{control.value.toFixed(control.decimals)}</output>
      </label>
    ))}
    <p class="canvas-meta">Drag the lens. The background, refraction, chroma and material are all drawn in one custom shader.</p>
  </div>
</section>

<script>
  import { mountLiquidGlassCanvas } from '../../labs/liquid-glass/canvasRuntime';

  document.querySelectorAll('[data-liquid-canvas-root]').forEach((root) => {
    mountLiquidGlassCanvas(root);
  });
</script>

<style>
  .liquid-canvas {
    --control-fill: var(--blue);
    --control-track: #252936;

    width: 100%;
    min-width: 0;
    overflow: hidden;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .stage-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-height: 52px;
    padding: 0 14px;
    background: color-mix(in srgb, var(--surface-2) 64%, transparent);
    border-bottom: 1px solid var(--line);
  }

  .stage-meta span {
    min-width: 0;
    overflow: hidden;
    color: var(--muted);
    font-size: 12px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stage-meta strong {
    min-width: 0;
    overflow: hidden;
    font-size: 14px;
    font-weight: 650;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .canvas-stage {
    position: relative;
    aspect-ratio: 16 / 9;
    min-height: 320px;
    overflow: hidden;
    background: #050609;
    cursor: grab;
    touch-action: none;
    user-select: none;
  }

  .canvas-stage:active {
    cursor: grabbing;
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .shader-badge {
    position: absolute;
    left: 14px;
    bottom: 14px;
    min-width: 0;
    max-width: calc(100% - 28px);
    padding: 9px 11px;
    color: rgba(245, 247, 252, .9);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, .18), rgba(255, 255, 255, .06)),
      rgba(8, 10, 16, .46);
    border: 1px solid rgba(255, 255, 255, .16);
    border-radius: 8px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .16),
      0 12px 28px rgba(0, 0, 0, .26);
    backdrop-filter: blur(18px) saturate(150%);
    -webkit-backdrop-filter: blur(18px) saturate(150%);
  }

  .shader-badge span,
  .shader-badge strong {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .shader-badge span {
    color: rgba(210, 216, 230, .66);
    font-size: 11px;
  }

  .shader-badge strong {
    margin-top: 2px;
    font-size: 12px;
    font-weight: 650;
  }

  .shader-badge .err {
    color: var(--amber);
  }

  .controls {
    min-width: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 28px;
    margin: 14px;
    padding: 14px;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .control {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr) 56px;
    align-items: center;
    gap: 14px;
    min-width: 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1;
  }

  .control span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .control output {
    color: var(--text);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  .control input[type="range"] {
    --range-percent: 0%;

    appearance: none;
    -webkit-appearance: none;
    min-width: 0;
    width: 100%;
    height: 20px;
    background: transparent;
    cursor: pointer;
  }

  .control input[type="range"]::-webkit-slider-runnable-track {
    height: 6px;
    background:
      linear-gradient(
        90deg,
        var(--control-fill) 0 var(--range-percent),
        var(--control-track) var(--range-percent) 100%
      );
    border-radius: 999px;
  }

  .control input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    margin-top: -5px;
    background: var(--text);
    border: 1px solid color-mix(in srgb, var(--blue) 45%, var(--line));
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, .32);
  }

  .control input[type="range"]::-moz-range-track {
    height: 6px;
    background: var(--control-track);
    border: 0;
    border-radius: 999px;
  }

  .control input[type="range"]::-moz-range-progress {
    height: 6px;
    background: var(--control-fill);
    border-radius: 999px;
  }

  .control input[type="range"]::-moz-range-thumb {
    width: 16px;
    height: 16px;
    background: var(--text);
    border: 1px solid color-mix(in srgb, var(--blue) 45%, var(--line));
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, .32);
  }

  .canvas-meta {
    grid-column: 1 / -1;
    margin: -2px 0 0;
    color: color-mix(in srgb, var(--muted) 78%, transparent);
    font-size: 12px;
    text-align: right;
  }

  @media (max-width: 880px) {
    .canvas-stage {
      min-height: 260px;
    }

    .controls {
      grid-template-columns: 1fr;
      gap: 14px;
      margin: 12px;
      padding: 12px;
    }
  }

  @media (max-width: 560px) {
    .stage-meta strong {
      display: none;
    }

    .control {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .control output,
    .canvas-meta {
      display: none;
    }
  }
</style>
