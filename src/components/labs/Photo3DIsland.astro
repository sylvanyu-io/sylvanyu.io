---
import defaultSpriteUrl from '../../labs/photo3d/textures/sprite1.png?url';

const title = 'Photo3D';
const category = 'WebGL / LDI';
---

<section class="photo3d-island" data-photo3d-root data-local-sprite={defaultSpriteUrl}>
  <div class="stage-meta">
    <span>{category}</span>
    <strong>{title}</strong>
  </div>
  <div class="canvas-wrap" data-photo3d-wrap>
    <div class="stage" data-photo3d-stage aria-label="Photo3D WebGL canvas">
      <div class="hud-actions" aria-label="Photo3D tools">
        <button
          class="hud-button"
          type="button"
          data-photo3d-stats-toggle
          aria-controls="photo3d-stats"
          aria-expanded="false"
        >
          Stats
        </button>
        <button
          class="hud-button"
          type="button"
          data-photo3d-panel-toggle
          aria-controls="photo3d-panel"
          aria-expanded="false"
        >
          参数
        </button>
      </div>
    </div>

    <aside id="photo3d-stats" class="stats-panel" data-photo3d-stats hidden>
      <div class="panel-head">
        <h2>Stats</h2>
        <p>runtime surface</p>
      </div>
      <dl class="stats-grid">
        <div>
          <dt>FPS</dt>
          <dd data-stat="fps">--</dd>
        </div>
        <div>
          <dt>View</dt>
          <dd data-stat="view">--</dd>
        </div>
        <div>
          <dt>Buffer</dt>
          <dd data-stat="buffer">--</dd>
        </div>
        <div>
          <dt>Image</dt>
          <dd data-stat="image">--</dd>
        </div>
        <div>
          <dt>DPR</dt>
          <dd data-stat="dpr">--</dd>
        </div>
        <div>
          <dt>Layers</dt>
          <dd data-stat="layers">--</dd>
        </div>
      </dl>
    </aside>

    <form id="photo3d-panel" class="panel" data-photo3d-panel hidden>
      <div class="panel-head">
        <h2>Photo3D</h2>
        <p>photo3d.fs · ray-marched LDI</p>
      </div>

      <div class="grp">位置偏移</div>
      <label class="row">
        <span>X 偏移</span>
        <input data-control="ox" type="range" min="-0.05" max="0.05" step="0.001" value="0.003" />
        <output data-output="ox"></output>
      </label>
      <label class="row">
        <span>Y 偏移</span>
        <input data-control="oy" type="range" min="-0.05" max="0.05" step="0.001" value="-0.01" />
        <output data-output="oy"></output>
      </label>
      <label class="row">
        <span>Z 偏移</span>
        <input data-control="oz" type="range" min="-0.1" max="0.3" step="0.001" value="0.176" />
        <output data-output="oz"></output>
      </label>

      <div class="grp">缩放与聚焦</div>
      <label class="row">
        <span>聚焦距离</span>
        <input data-control="focus" type="range" min="0" max="1" step="0.01" value="0.51" />
        <output data-output="focus"></output>
      </label>
      <label class="chk">
        <input data-control="highlight" type="checkbox" />
        <span>聚焦高亮</span>
      </label>
      <label class="row">
        <span>整体缩放</span>
        <input data-control="crop" type="range" min="0.8" max="1.3" step="0.01" value="0.97" />
        <output data-output="crop"></output>
      </label>

      <div class="grp">图层与边缘</div>
      <div class="row segmented-row">
        <span>图层数量</span>
        <div class="seg" data-layers>
          <button type="button" data-n="1">1</button>
          <button type="button" data-n="2">2</button>
          <button type="button" data-n="3">3</button>
        </div>
      </div>
      <label class="row">
        <span>羽化宽度</span>
        <input data-control="feather" type="range" min="0" max="3" step="0.1" value="1.0" />
        <output data-output="feather"></output>
      </label>
      <label class="row">
        <span>边缘锐度</span>
        <input data-control="sharp" type="range" min="0" max="20" step="1" value="10" />
        <output data-output="sharp"></output>
      </label>

      <div class="grp">图源 URL</div>
      <input data-url-input type="url" class="urlin" placeholder="https://.../sprite.png" />
      <button type="button" data-load-url class="loadbtn">载入 URL</button>
    </form>

    <p class="status" data-photo3d-status>Initializing...</p>
  </div>
</section>

<script>
  import shaderBody from '../../labs/photo3d/photo3d.fs?raw';
  import { mountPhoto3D } from '../../labs/photo3d/runtime';

  document.querySelectorAll('[data-photo3d-root]').forEach((root) => {
    mountPhoto3D(root, { shaderBody });
  });
</script>

<style>
  .photo3d-island {
    --photo3d-aspect: 1024 / 640;

    width: 100%;
    min-width: 0;
    overflow: hidden;
    overscroll-behavior: contain;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .stage-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-height: 48px;
    padding: 0 14px;
    border-bottom: 1px solid var(--line);
  }

  .stage-meta span {
    color: var(--muted);
    font-size: 12px;
  }

  .stage-meta strong {
    min-width: 0;
    overflow: hidden;
    font-size: 14px;
    font-weight: 650;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .canvas-wrap {
    position: relative;
    width: 100%;
    height: auto;
    min-height: 0;
    overflow: hidden;
    overscroll-behavior: contain;
    background: #050609;
  }

  .stage {
    position: relative;
    width: 100%;
    aspect-ratio: var(--photo3d-aspect);
    overflow: hidden;
    background: #000;
  }

  canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    background: #000;
    touch-action: none;
  }

  .hud-actions {
    position: absolute;
    right: 10px;
    bottom: 10px;
    z-index: 3;
    display: flex;
    gap: 6px;
  }

  .hud-button {
    min-width: 0;
    min-height: 28px;
    padding: 0 10px;
    color: rgba(232, 234, 240, .62);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .14), rgba(255, 255, 255, .06)),
      rgba(18, 21, 28, .42);
    border: 1px solid rgba(255, 255, 255, .12);
    border-radius: 999px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .1),
      inset 0 -1px 0 rgba(255, 255, 255, .07),
      0 6px 16px rgba(0, 0, 0, .2);
    font: inherit;
    font-size: 11px;
    line-height: 1;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: pointer;
    opacity: .68;
    transition: opacity .16s ease, color .16s ease, border-color .16s ease, background .16s ease;
  }

  .hud-button:hover,
  .hud-button.is-open {
    color: rgba(255, 255, 255, .94);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .2), rgba(255, 255, 255, .08)),
      rgba(24, 27, 35, .6);
    border-color: rgba(255, 255, 255, .18);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .12),
      inset 0 -1px 0 rgba(255, 255, 255, .09),
      0 7px 18px rgba(0, 0, 0, .22);
    opacity: 1;
  }

  .panel,
  .stats-panel {
    position: absolute;
    top: 12px;
    z-index: 2;
    color: rgba(245, 247, 252, .92);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, .18), rgba(255, 255, 255, .055) 44%, rgba(126, 224, 138, .075)),
      rgba(15, 18, 26, .56);
    border: 1px solid rgba(255, 255, 255, .17);
    border-radius: 18px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .24),
      inset 0 -1px 0 rgba(255, 255, 255, .06),
      0 22px 70px rgba(0, 0, 0, .38);
    backdrop-filter: blur(24px) saturate(165%);
    -webkit-backdrop-filter: blur(24px) saturate(165%);
  }

  .panel {
    left: 12px;
    width: 272px;
    max-width: calc(100% - 24px);
    max-height: calc(100% - 24px);
    padding: 10px 11px;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    border-radius: 16px;
    scrollbar-color: rgba(255, 255, 255, .28) transparent;
    scrollbar-width: thin;
    user-select: none;
  }

  .panel::-webkit-scrollbar {
    width: 6px;
  }

  .panel::-webkit-scrollbar-track {
    background: transparent;
  }

  .panel::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, .24);
    border-radius: 999px;
  }

  .stats-panel {
    right: 12px;
    width: 218px;
    max-width: calc(100% - 24px);
    padding: 13px 14px 14px;
  }

  .panel[hidden],
  .stats-panel[hidden] {
    display: none;
  }

  .panel-head h2 {
    margin: 0 0 2px;
    font-size: 13px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .panel-head p {
    margin: 0 0 8px;
    color: rgba(210, 216, 230, .68);
    font-size: 11px;
    line-height: 1.35;
  }

  .panel > .panel-head p {
    display: none;
  }

  .grp {
    margin: 8px 0 3px;
    color: rgba(210, 216, 230, .56);
    font-size: 9px;
    line-height: 1.2;
  }

  .row {
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) 36px;
    align-items: center;
    gap: 7px;
    min-width: 0;
    margin: 4px 0;
    color: rgba(210, 216, 230, .7);
    font-size: 11px;
  }

  .row output {
    color: var(--text);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  input[type="range"] {
    min-width: 0;
    width: 100%;
    accent-color: var(--green);
  }

  .chk {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 2px 0;
    color: rgba(210, 216, 230, .76);
    font-size: 11px;
    cursor: pointer;
  }

  .segmented-row {
    grid-template-columns: 54px minmax(0, 1fr);
  }

  .seg {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    min-width: 0;
  }

  .seg button,
  .loadbtn {
    color: rgba(232, 234, 240, .72);
    background: rgba(255, 255, 255, .075);
    border: 1px solid rgba(255, 255, 255, .12);
    border-radius: 10px;
    font: inherit;
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
  }

  .seg button {
    min-height: 22px;
  }

  .seg button.on {
    color: #ddffe2;
    background: rgba(126, 224, 138, .22);
    border-color: rgba(126, 224, 138, .42);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .12);
  }

  .urlin {
    width: 100%;
    min-width: 0;
    color: var(--text);
    background: rgba(255, 255, 255, .075);
    border: 1px solid rgba(255, 255, 255, .12);
    border-radius: 10px;
    padding: 6px 8px;
    font: inherit;
    font-size: 11px;
  }

  .loadbtn {
    width: 100%;
    min-height: 28px;
    margin-top: 6px;
    color: #cdffd4;
    background:
      linear-gradient(135deg, rgba(126, 224, 138, .32), rgba(126, 224, 138, .16)),
      rgba(34, 80, 43, .42);
    border-color: rgba(126, 224, 138, .38);
  }

  .stats-grid {
    display: grid;
    gap: 7px;
    margin: 9px 0 0;
  }

  .stats-grid div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    min-width: 0;
    padding-bottom: 7px;
    border-bottom: 1px solid rgba(255, 255, 255, .08);
  }

  .stats-grid div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .stats-grid dt,
  .stats-grid dd {
    margin: 0;
    font-size: 11px;
    line-height: 1.2;
  }

  .stats-grid dt {
    color: rgba(210, 216, 230, .58);
  }

  .stats-grid dd {
    min-width: 0;
    overflow: hidden;
    color: rgba(245, 247, 252, .92);
    font-variant-numeric: tabular-nums;
    text-align: right;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status {
    position: absolute;
    left: 12px;
    bottom: 10px;
    z-index: 2;
    margin: 0;
    padding: 6px 10px;
    color: rgba(232, 234, 240, .66);
    background: rgba(5, 6, 9, .42);
    border: 1px solid rgba(232, 234, 240, .12);
    border-radius: 8px;
    font-size: 12px;
    line-height: 1;
  }

  .status[hidden] {
    display: none;
  }

  .status.err {
    color: var(--amber);
    border-color: rgba(242, 189, 116, .34);
  }

  @media (max-width: 760px) {
    .stage-meta {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      gap: 2px;
      padding-block: 8px;
    }

    .panel {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      max-width: none;
      max-height: none;
      padding: 11px 12px;
      overflow: visible;
      border-right: 0;
      border-left: 0;
      border-radius: 0 0 18px 18px;
    }

    .stats-panel {
      position: relative;
      top: auto;
      right: auto;
      width: 100%;
      max-width: none;
      border-right: 0;
      border-left: 0;
      border-radius: 0;
    }

    .row {
      grid-template-columns: 56px minmax(72px, 1fr) 38px;
      gap: 6px;
      font-size: 11px;
    }

    .segmented-row {
      grid-template-columns: 56px minmax(0, 1fr);
    }

    .grp {
      margin-top: 9px;
    }

    .status {
      position: static;
      display: inline-block;
      margin: 9px 10px 10px;
    }
  }
</style>
